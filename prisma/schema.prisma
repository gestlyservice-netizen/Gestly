// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  clerkId              String    @unique
  email                String
  companyName          String
  siret                String?
  address              String?
  phone                String?
  logoUrl              String?
  defaultRemindDelay   Int       @default(7)
  defaultRemindMessage String?
  subscriptionStatus   String    @default("trial")
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  createdAt            DateTime  @default(now())

  clients  Client[]
  devis    Devis[]
  factures Facture[]
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  devis    Devis[]
  factures Facture[]
}

model Devis {
  id           String    @id @default(cuid())
  userId       String
  clientId     String
  number       String
  status       String    @default("brouillon")
  totalHT      Float     @default(0)
  totalTVA     Float     @default(0)
  totalTTC     Float     @default(0)
  validityDays Int       @default(30)
  notes        String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
  signedAt     DateTime?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lines    DevisLine[]
  factures Facture[]
}

model DevisLine {
  id          String @id @default(cuid())
  devisId     String
  description String
  quantity    Float
  unitPriceHT Float
  tvaRate     Float  @default(20)
  totalHT     Float

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model Facture {
  id        String    @id @default(cuid())
  userId    String
  clientId  String
  devisId   String?
  number    String
  totalHT   Float
  totalTVA  Float
  totalTTC  Float
  status    String    @default("emise")
  notes     String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  devis  Devis?        @relation(fields: [devisId], references: [id], onDelete: SetNull)
  lines  FactureLine[]
}

model FactureLine {
  id          String  @id @default(cuid())
  factureId   String
  description String
  quantity    Float
  unitPriceHT Float
  tvaRate     Float   @default(20)
  totalHT     Float

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
}
