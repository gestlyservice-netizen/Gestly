// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  clerkId              String    @unique
  email                String
  companyName          String
  siret                String?
  address              String?
  phone                String?
  logoUrl              String?
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  subscriptionStatus      String    @default("trialing")
  trialEndsAt             DateTime  @default(dbgenerated("NOW() + INTERVAL '14 days'"))
  stripeCurrentPeriodEnd  DateTime?
  stripeCancelAtPeriodEnd Boolean   @default(false)
  plan                    String    @default("starter")
  createdAt            DateTime  @default(now())

  clients         Client[]
  devis           Devis[]
  factures        Facture[]
  avoirs          Avoir[]
  settings        Settings?
  relanceSettings RelanceSettings?
  events          Event[]
  notifications   Notification[]
  opportunities   Opportunity[]
}

model Client {
  id               String   @id @default(cuid())
  userId           String
  name             String
  email            String?
  phone            String?
  address          String?
  preferredContact String   @default("email")
  createdAt        DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  devis         Devis[]
  factures      Facture[]
  avoirs        Avoir[]
  events        Event[]
  opportunities Opportunity[]
}

model Devis {
  id           String    @id @default(cuid())
  userId       String
  clientId     String
  number       String
  status       String    @default("brouillon")
  totalHT      Float     @default(0)
  totalTVA     Float     @default(0)
  totalTTC     Float     @default(0)
  validityDays Int       @default(30)
  notes        String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
  signedAt     DateTime?

  // Lien public de partage (§ Phase 3.3) : le devis reste identifié par son id,
  // mais l'accès public (non-propriétaire) peut être révoqué ou expirer.
  // Le propriétaire authentifié n'est jamais bloqué par ces champs.
  linkExpiresAt DateTime?
  linkRevoked   Boolean   @default(false)

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lines    DevisLine[]
  factures Facture[]
}

model DevisLine {
  id          String @id @default(cuid())
  devisId     String
  description String
  quantity    Float
  unitPriceHT Float
  tvaRate     Float  @default(20)
  totalHT     Float

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model Facture {
  id        String    @id @default(cuid())
  userId    String
  clientId  String
  devisId   String?
  number    String
  totalHT   Float
  totalTVA  Float
  totalTTC  Float
  status    String    @default("emise")
  notes     String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  paidAt    DateTime?
  sentAt    DateTime?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  devis    Devis?        @relation(fields: [devisId], references: [id], onDelete: SetNull)
  lines    FactureLine[]
  avoirs   Avoir[]
  relances Relance[]
}

model FactureLine {
  id          String  @id @default(cuid())
  factureId   String
  description String
  quantity    Float
  unitPriceHT Float
  tvaRate     Float   @default(20)
  totalHT     Float

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @unique

  // Section 1 — Informations entreprise
  companyName           String   @default("")
  formeJuridique        String?
  siret                 String?
  tvaIntracom           String?
  adresseRue            String?
  codePostal            String?
  ville                 String?
  telephone             String?
  emailPro              String?
  siteWeb               String?

  // Section 2 — Apparence
  logoUrl               String?
  couleurPrincipale     String   @default("#2563EB")
  piedDePage            String?

  // Section 3 — Numérotation
  prefixeDevis          String   @default("DEV-")
  prefixeFacture        String   @default("FAC-")
  prochainNumeroDevis   Int      @default(1)
  prochainNumeroFacture Int      @default(1)

  // Section 4 — Mentions légales
  conditionsPaiement    String?
  penalitesRetard       String?
  reservePropriete      Boolean  @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OvhBalanceAlert {
  id          String   @id @default(cuid())
  creditsLeft Int
  threshold   Int
  alertSentAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ── Avoirs (notes de crédit) ────────────────────────────────
// Une facture émise n'est jamais modifiée ni supprimée (conforme au droit
// français) : toute correction passe par un avoir référençant la facture
// d'origine, total ou partiel.
model Avoir {
  id        String   @id @default(cuid())
  userId    String
  factureId String
  clientId  String
  number    String
  type      String   @default("total") // "total" | "partiel"
  reason    String
  totalHT   Float
  totalTVA  Float
  totalTTC  Float
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  facture Facture     @relation(fields: [factureId], references: [id], onDelete: Cascade)
  client  Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lines   AvoirLine[]
}

model AvoirLine {
  id          String @id @default(cuid())
  avoirId     String
  description String
  quantity    Float
  unitPriceHT Float
  tvaRate     Float  @default(20)
  totalHT     Float

  avoir Avoir @relation(fields: [avoirId], references: [id], onDelete: Cascade)
}

// ── Relances automatiques de factures ───────────────────────
model RelanceSettings {
  id         String   @id @default(cuid())
  userId     String   @unique
  enabled    Boolean  @default(false)
  delaiJ1    Int      @default(3)
  delaiJ2    Int      @default(10)
  delaiJ3    Int      @default(21)
  canalEmail Boolean  @default(true)
  canalSms   Boolean  @default(false)
  messageJ1  String?
  messageJ2  String?
  messageJ3  String?
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Relance {
  id        String   @id @default(cuid())
  factureId String
  niveau    Int
  canal     String // "email" | "sms"
  statut    String // "envoyee" | "echec"
  erreur    String?
  envoyeeAt DateTime @default(now())

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@unique([factureId, niveau, canal])
}

// ── Agenda ───────────────────────────────────────────────────
model Event {
  id                    String    @id @default(cuid())
  userId                String
  clientId              String?
  title                 String
  description           String?
  address               String?
  startAt               DateTime
  endAt                 DateTime?
  reminderMinutesBefore Int?
  createdAt             DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
}

// ── Notifications internes ──────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ── Pipeline commercial CRM (opportunités) ──────────────────
// Distinct du Kanban de suivi des devis : une opportunité peut exister avant
// même qu'un devis soit rédigé.
model Opportunity {
  id              String    @id @default(cuid())
  userId          String
  clientId        String?
  title           String
  amount          Float?
  probability     Int       @default(50)
  stage           String    @default("nouveau") // nouveau, qualification, proposition, negociation, gagne, perdu
  expectedCloseAt DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, stage])
}
